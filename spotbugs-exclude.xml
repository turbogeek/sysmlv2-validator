<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter
    xmlns="https://github.com/spotbugs/filter/3.0.0"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="https://github.com/spotbugs/filter/3.0.0 https://raw.githubusercontent.com/spotbugs/spotbugs/3.1.0/spotbugs/etc/findbugsfilter.xsd">

    <!-- Exclude ANTLR generated files -->
    <Match>
        <Class name="~.*\.SysMLv2Lexer.*"/>
    </Match>
    <Match>
        <Class name="~.*\.SysMLv2Parser.*"/>
    </Match>
    <Match>
        <Class name="~.*\.SysMLv2ParserBase.*"/>
    </Match>

    <!-- Exclude test files from certain checks -->
    <Match>
        <Class name="~.*Test"/>
        <Bug pattern="DM_NUMBER_CTOR"/>
    </Match>

    <!-- Allow inner assignments in visitor pattern (common in ANTLR visitors) -->
    <Match>
        <Class name="~.*Builder"/>
        <Bug pattern="BC_UNCONFIRMED_CAST"/>
    </Match>

    <!-- Allow serialization issues in Location (not serialized in practice) -->
    <Match>
        <Class name="com.validator.ast.Location"/>
        <Bug pattern="SE_NO_SERIALVERSIONID"/>
    </Match>

    <!-- Allow public fields in data transfer objects (if any) -->
    <Match>
        <Package name="~com\.validator\.ast.*"/>
        <Bug pattern="MS_PKGPROTECT"/>
    </Match>

</FindBugsFilter>
